<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111111">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Affiche du film -->
        <ImageView
            android:id="@+id/imgAfficheDetail"
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:scaleType="centerCrop" />

        <!-- Titre du film -->
        <TextView
            android:id="@+id/tvTitreDetail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

        <!-- Note TMDB -->
        <TextView
            android:id="@+id/tvNoteDetail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="#E24B4A"
            android:textSize="16sp" />

        <!-- Synopsis -->
        <TextView
            android:id="@+id/tvSynopsisDetail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="#AAAAAA"
            android:textSize="14sp" />
        <!-- TableLayout pour afficher les infos du film -->
        <TableLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:stretchColumns="1">

            <TableRow>
                <TextView
                    android:padding="4dp"
                    android:text="Genre :"
                    android:textColor="#888888"
                    android:textSize="13sp" />
                <TextView
                    android:padding="4dp"
                    android:text="Action"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp" />
            </TableRow>

            <TableRow>
                <TextView
                    android:padding="4dp"
                    android:text="Langue :"
                    android:textColor="#888888"
                    android:textSize="13sp" />
                <TextView
                    android:padding="4dp"
                    android:text="Français"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp" />
            </TableRow>

            <TableRow>
                <TextView
                    android:padding="4dp"
                    android:text="Statut :"
                    android:textColor="#888888"
                    android:textSize="13sp" />
                <TextView
                    android:padding="4dp"
                    android:text="En collection"
                    android:textColor="#E24B4A"
                    android:textSize="13sp" />
            </TableRow>

        </TableLayout>
        <!-- Séparateur -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            android:background="#333333" />

        <!-- Statut du film -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:text="Statut :"
            android:textSize="14sp" />

        <Spinner
            android:id="@+id/spinnerStatut"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp" />

        <!-- Note personnelle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textColor="#FFFFFF"
            android:text="Ma note :"
            android:textSize="14sp" />

        <RatingBar
            android:id="@+id/ratingBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:numStars="5"
            android:stepSize="1" />

        <!-- Avis écrit -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textColor="#FFFFFF"
            android:text="Mon avis :"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/etAvis"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:backgroundTint="#E24B4A"
            android:hint="Écris ton avis ici..."
            android:textColor="#FFFFFF"
            android:textColorHint="#888888"
            android:minLines="3" />
        <!-- Date de visionnage -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textColor="#FFFFFF"
            android:text="Date de visionnage :"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btnDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="#333333"
            android:text="Choisir une date"
            android:textColor="#FFFFFF" />

        <TextView
            android:id="@+id/tvDateChoisie"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#E24B4A"
            android:text=""
            android:textSize="14sp" />
        <!-- Bouton Ajouter à la collection -->
        <Button
            android:id="@+id/btnAjouter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="#E24B4A"
            android:text="Ajouter à ma collection"
            android:textColor="#FFFFFF" />

    </LinearLayout>

</ScrollView>